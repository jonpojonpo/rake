# ── LLM ──────────────────────────────────────────────────────────────────────
# At least one of these is required
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...          # optional; used when RAKE_LLM=openai

# Which LLM backend to use: claude | openai | ollama | noop
RAKE_LLM=claude

# Model override (leave blank to use the SDK default)
# Examples: claude-sonnet-4-6  gpt-4o  llama3
RAKE_MODEL=

# Maximum seconds to wait for analysis to complete
RAKE_TIMEOUT=300

# ── S3 results storage ───────────────────────────────────────────────────────
# If S3_RESULTS_BUCKET is empty, output files are returned inline (no S3 upload).
S3_RESULTS_BUCKET=rake-results

# Key prefix inside the bucket (include trailing slash)
S3_RESULTS_PREFIX=rake-results/

# How long presigned download URLs stay valid (seconds)
S3_PRESIGN_TTL_SECONDS=3600

# ── AWS credentials ──────────────────────────────────────────────────────────
AWS_DEFAULT_REGION=us-east-1

# For real AWS: set these or use IRSA / instance profile / env-based auth
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# For LocalStack / MinIO: override the S3 endpoint
# AWS_ENDPOINT_URL=http://localhost:4566
