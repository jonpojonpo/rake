# Development Dockerfile for local testing without Azure Functions runtime.
# Exposes a simple FastAPI server that mimics the function endpoints.
#
# Usage:
#   docker build -f docker/Dockerfile.local -t rake-local .
#   docker run -p 8000:8000 \
#     -e ANTHROPIC_API_KEY=sk-... \
#     rake-local

# ── Stage 1: Build rake binary ───────────────────────────────────────────────
FROM rust:1.82-slim AS rust-builder
WORKDIR /build
COPY Cargo.toml Cargo.lock ./
RUN mkdir -p src && echo 'fn main(){}' > src/main.rs && \
    cargo build --release && rm -rf src
COPY src ./src
RUN touch src/main.rs && cargo build --release

# ── Stage 2: Python dev server ───────────────────────────────────────────────
FROM python:3.11-slim

COPY --from=rust-builder /build/target/release/rake /usr/local/bin/rake
RUN chmod +x /usr/local/bin/rake

WORKDIR /app

COPY python/requirements.txt requirements.txt
RUN pip install --no-cache-dir -r requirements.txt fastapi uvicorn

COPY python/rake_sdk rake_sdk/
COPY python/services services/
COPY docker/local_server.py local_server.py

ENV RAKE_BINARY=/usr/local/bin/rake
ENV RAKE_LLM=claude
ENV RAKE_TIMEOUT=240

EXPOSE 8000
CMD ["uvicorn", "local_server:app", "--host", "0.0.0.0", "--port", "8000"]
